---
import { getChurchConfig } from '../lib/church';

const config = getChurchConfig();
---

<footer class="bg-primary text-white mt-auto">
  <div class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="font-semibold text-lg mb-2">{config.shortName}</h3>
        <p class="text-white/90 text-sm">{config.address}</p>
        <p class="text-white/90 text-sm">CEP: {config.cep}</p>
        {config.phone && <p class="text-white/90 text-sm mt-1">Tel: {config.phone}</p>}
        {config.email && <p class="text-white/90 text-sm">Email: {config.email}</p>}
      </div>
      <div>
        <h3 class="font-semibold text-lg mb-2">Links</h3>
        <ul class="flex flex-col gap-2 text-sm text-white/90">
          <li><a href="/" class="hover:underline">Início</a></li>
          <li><a href="/noticias" class="hover:underline">Notícias</a></li>
          <li><a href="/horarios" class="hover:underline">Horários</a></li>
          <li><a href="/folheto" class="hover:underline">Folheto Litúrgico</a></li>
          <li><a href="/grupos" class="hover:underline">Grupos e Pastorais</a></li>
          <li><a href="/formacao" class="hover:underline">Formação</a></li>
          <li><a href="/contato" class="hover:underline">Contato</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/20 mt-8 pt-6 text-center text-sm text-white/80">
      &copy; {new Date().getFullYear()} {config.name}. Todos os direitos reservados.
    </div>
  </div>
</footer>
