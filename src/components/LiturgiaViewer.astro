---
import { CANCAO_NOVA_URL } from '../lib/liturgia';
---

<div class="liturgia-viewer space-y-6" id="liturgia-root">
  <div class="flex flex-wrap items-center gap-4">
    <label class="flex items-center gap-2">
      <span class="text-sm font-medium text-gray-700">Data:</span>
      <input
        type="date"
        id="liturgia-date"
        class="rounded-lg border border-gray-300 px-3 py-2 text-base min-h-[44px]"
      />
    </label>
    <a
      href={CANCAO_NOVA_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-primary hover:underline"
    >
      Ver na Canção Nova
    </a>
  </div>
  <div id="liturgia-cor" class="hidden w-3 h-3 rounded-full mb-2" aria-hidden="true"></div>
  <h2 id="liturgia-titulo" class="text-xl font-semibold text-gray-900">Carregando...</h2>
  <div id="liturgia-conteudo" class="space-y-8 text-gray-800 font-serif text-lg leading-relaxed">
    <p>Carregando leituras...</p>
  </div>
  <div id="liturgia-erro" class="hidden p-4 rounded-lg bg-red-50 text-red-800">
    Não foi possível carregar a liturgia. <a href={CANCAO_NOVA_URL} target="_blank" rel="noopener noreferrer" class="underline">Acesse a liturgia na Canção Nova</a>.
  </div>
</div>

<script>
  const API_URL = 'https://liturgia.up.railway.app/v2/';
  const root = document.getElementById('liturgia-root');
  const dateInput = document.getElementById('liturgia-date') as HTMLInputElement;
  const corEl = document.getElementById('liturgia-cor');
  const tituloEl = document.getElementById('liturgia-titulo');
  const conteudoEl = document.getElementById('liturgia-conteudo');
  const erroEl = document.getElementById('liturgia-erro');

  const COR_MAP: Record<string, string> = {
    roxo: '#6b2d5c',
    verde: '#2d5c3e',
    branco: '#f5f5f5',
    vermelho: '#8b1a1a',
    rosa: '#c77b9a',
  };

  function formatDate(d: Date): string {
    const day = d.getDate();
    const month = d.getMonth() + 1;
    return `${d.getFullYear()}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  }

  function setToday() {
    const today = new Date();
    if (dateInput) dateInput.value = formatDate(today);
  }

  function renderLeitura(label: string, ref: string | undefined, texto: string | undefined) {
    if (!ref && !texto) return '';
    return `
      <section class="space-y-2">
        <h3 class="text-base font-sans font-semibold text-primary uppercase tracking-wide">${label}</h3>
        ${ref ? `<p class="text-sm text-gray-600 font-sans">${ref}</p>` : ''}
        <div class="whitespace-pre-wrap text-[1.05rem]">${(texto || '').replace(/\n/g, '<br>')}</div>
      </section>
    `;
  }

  async function load(dia: number, mes: number) {
    if (!conteudoEl || !tituloEl || !erroEl) return;
    erroEl.classList.add('hidden');
    conteudoEl.innerHTML = '<p>Carregando...</p>';
    try {
      const res = await fetch(`${API_URL}?dia=${dia}&mes=${mes}`);
      const data = await res.json();
      if (!data.leituras) throw new Error('Sem leituras');
      const lit = data.leituras;
      tituloEl.textContent = data.liturgia || 'Liturgia do dia';
      if (corEl && data.cor) {
        const cor = COR_MAP[data.cor.toLowerCase()] || data.cor;
        corEl.style.background = cor;
        corEl.classList.remove('hidden');
      }
      const html = [
        lit.primeiraLeitura?.[0] && renderLeitura('Primeira Leitura', lit.primeiraLeitura[0].referencia, lit.primeiraLeitura[0].texto),
        lit.salmo?.[0] && renderLeitura('Salmo', lit.salmo[0].referencia, lit.salmo[0].texto),
        lit.segundaLeitura?.[0] && renderLeitura('Segunda Leitura', lit.segundaLeitura[0].referencia, lit.segundaLeitura[0].texto),
        lit.evangelho?.[0] && renderLeitura('Evangelho', lit.evangelho[0].referencia, lit.evangelho[0].texto),
      ].filter(Boolean).join('');
      conteudoEl.innerHTML = html || '<p>Nenhuma leitura disponível.</p>';
    } catch (e) {
      conteudoEl.innerHTML = '';
      erroEl.classList.remove('hidden');
    }
  }

  setToday();
  const today = new Date();
  load(today.getDate(), today.getMonth() + 1);

  dateInput?.addEventListener('change', () => {
    const d = new Date(dateInput.value);
    if (!isNaN(d.getTime())) load(d.getDate(), d.getMonth() + 1);
  });
</script>
