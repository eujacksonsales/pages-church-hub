---
import type { ChurchSchedule } from '../lib/church';

interface Props {
  schedule: ChurchSchedule;
  compact?: boolean;
}

const { schedule, compact = false } = Astro.props;
const DAYS_ORDER = ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'];
const sorted = [...schedule.missas].sort((a, b) => DAYS_ORDER.indexOf(a.dia) - DAYS_ORDER.indexOf(b.dia));
---

<div class="bg-white rounded-xl border border-gray-200 p-4 md:p-6 shadow-sm">
  <h3 class="font-semibold text-lg text-primary mb-4">Horário das Missas</h3>
  <ul class="space-y-3">
    {sorted.map(({ dia, horarios }) => (
      <li class="flex flex-wrap items-center gap-2">
        <span class="font-medium text-gray-800 min-w-[120px]">{dia}</span>
        <span class="text-gray-600">{horarios.join(', ')}</span>
      </li>
    ))}
  </ul>
  {schedule.batismo && (
    <p class="mt-4 pt-4 border-t border-gray-100 text-sm text-gray-600">
      <strong>Batismo:</strong> {schedule.batismo}
    </p>
  )}
  {schedule.catequese && (
    <p class="mt-1 text-sm text-gray-600">
      <strong>Catequese:</strong> {schedule.catequese}
    </p>
  )}
</div>
