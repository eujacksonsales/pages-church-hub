---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getChurchId } from '../../lib/church';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const { getChurchId } = await import('../../lib/church');
  const churchId = getChurchId();
  const formacao = await getCollection('formacao', ({ data }) => data.church === churchId);
  return formacao.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const churchId = getChurchId();
if (entry.data.church !== churchId) {
  return Astro.redirect('/formacao');
}

const { render } = await import('astro:content');
const { Content } = await render(entry);
const pubDateStr = entry.data.pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout>
  <Fragment slot="head">
    <title>{entry.data.title}</title>
    {entry.data.description && <meta name="description" content={entry.data.description} />}
  </Fragment>

  <article class="container mx-auto px-4 py-8 max-w-3xl">
    <header class="mb-6">
      <div class="flex flex-wrap gap-2 text-sm text-gray-500 mb-2">
        <time datetime={entry.data.pubDate.toISOString()}>{pubDateStr}</time>
        {entry.data.category && (
          <span class="px-2 py-0.5 rounded bg-primary/10 text-primary">{entry.data.category}</span>
        )}
        {entry.data.author && <span>{entry.data.author}</span>}
      </div>
      <h1 class="text-3xl font-bold text-gray-900">{entry.data.title}</h1>
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
    <a href="/formacao" class="inline-block mt-8 text-primary font-medium hover:underline">Voltar à formação</a>
  </article>
</BaseLayout>
