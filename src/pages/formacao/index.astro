---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getChurchId } from '../../lib/church';
import { getCollection } from 'astro:content';

const churchId = getChurchId();
const allFormacao = await getCollection('formacao', ({ data }) => data.church === churchId);
const sorted = allFormacao.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout>
  <Fragment slot="head">
    <title>Formação</title>
  </Fragment>

  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Formação</h1>
    <p class="text-gray-600 mb-8">Artigos para aprofundar a fé e o conhecimento da Igreja.</p>

    {sorted.length > 0 ? (
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
        {sorted.map((entry) => (
          <li>
            <a
              href={`/formacao/${entry.id}`}
              class="block rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:shadow-md transition-shadow"
            >
              <span class="text-sm text-gray-500">
                {entry.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
              </span>
              {entry.data.category && (
                <span class="ml-2 text-xs px-2 py-0.5 rounded bg-primary/10 text-primary">{entry.data.category}</span>
              )}
              <h2 class="mt-2 font-semibold text-lg text-gray-900">{entry.data.title}</h2>
              {entry.data.description && <p class="mt-1 text-sm text-gray-600 line-clamp-2">{entry.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-gray-500">Nenhum artigo publicado ainda.</p>
    )}
  </div>
</BaseLayout>
