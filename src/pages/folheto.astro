---
import BaseLayout from '../layouts/BaseLayout.astro';
import LiturgiaViewer from '../components/LiturgiaViewer.astro';
import { getChurchConfig } from '../lib/church';

const config = getChurchConfig();
---

<BaseLayout>
  <Fragment slot="head">
    <title>Folheto Litúrgico - {config.shortName}</title>
    <meta name="description" content="Liturgia do dia - leituras da missa" />
  </Fragment>

  <div class="container mx-auto px-4 py-8 max-w-3xl">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Folheto Litúrgico</h1>
    <p class="text-gray-600 mb-6">Leituras da liturgia do dia</p>
    <LiturgiaViewer />
  </div>
</BaseLayout>
