---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getChurchId } from '../../lib/church';
import { getCollection } from 'astro:content';

const churchId = getChurchId();
const allNoticias = await getCollection('noticias', ({ data }) => data.church === churchId);
const sorted = allNoticias.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const NEW_DAYS = 7;
const now = Date.now();
---

<BaseLayout>
  <Fragment slot="head">
    <title>Notícias</title>
  </Fragment>

  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Notícias</h1>
    {sorted.length > 0 ? (
      <ul class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {sorted.map((entry) => {
          const isNew = (now - entry.data.pubDate.getTime()) / (1000 * 60 * 60 * 24) < NEW_DAYS;
          return (
            <li>
              <NewsCard
                slug={entry.id}
                title={entry.data.title}
                description={entry.data.description}
                pubDate={entry.data.pubDate}
                category={entry.data.category}
                image={entry.data.image}
                isNew={isNew}
              />
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="text-gray-500">Nenhuma notícia publicada ainda.</p>
    )}
  </div>
</BaseLayout>
