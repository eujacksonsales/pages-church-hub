---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { getChurchConfig, getChurchId } from '../lib/church';
import { getCollection } from 'astro:content';

const config = getChurchConfig();
const theme = config.theme;
const churchId = getChurchId();
const allNoticias = await getCollection('noticias', ({ data }) => data.church === churchId);
const NEW_DAYS = 7;
const now = Date.now();
const recentCount = allNoticias.filter(
  (e) => (now - e.data.pubDate.getTime()) / (1000 * 60 * 60 * 24) < NEW_DAYS
).length;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={config.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body
    class="min-h-screen flex flex-col"
    style={{
      '--church-primary': theme.primary,
      '--church-secondary': theme.secondary,
      '--church-accent': theme.accent,
      '--church-background': theme.background,
      '--church-text': theme.text,
    }}
  >
    <Header recentCount={recentCount} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
